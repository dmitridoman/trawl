# Off-page / ranking API keys for trawl. All optional — a missing key just makes
# that one signal render as "unavailable"; nothing else is affected. See the
# "Off-page & ranking signals" section of the README.

# Domain authority (0–10), backlink-derived. Free: https://www.domcop.com/openpagerank/
CRAWLSHOT_OPENPAGERANK_KEY=

# Real-world field Core Web Vitals from Chrome UX Report (CrUX). A free Google API
# key with the "Chrome UX Report API" enabled. Also covers PageSpeed if you add it.
CRAWLSHOT_GOOGLE_KEY=

# Keyword SERP positions via Brave Search. Free tier: https://brave.com/search/api/
# Only used when you pass --rank "keyword one, keyword two".
CRAWLSHOT_BRAVE_KEY=

# Search volume / CPC / competition for the same --rank keywords, via Keywords
# Everywhere: https://keywordseverywhere.com/ — works independently of the Brave
# key above (set either or both).
CRAWLSHOT_KEYWORDS_EVERYWHERE_KEY=

# Google Search Console is NOT an env key — pass --gsc-credentials <path> to a JSON
# file holding either an OAuth access_token or a service-account key (client_email +
# private_key) for a property that has been shared with it.

# Runs Lighthouse via PageSpeed Insights instead of a local Chrome instance — no
# local compute, no local-machine load skewing scores. Enable the "PageSpeed
# Insights API" in Google Cloud Console to get a key. Only used for unauthenticated
# crawls (no --auth-storage) and public URLs; falls back to local Lighthouse
# otherwise, or on a per-page PSI failure.
CRAWLSHOT_PSI_KEY=
